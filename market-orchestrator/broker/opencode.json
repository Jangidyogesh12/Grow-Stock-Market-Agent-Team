{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "kernel": {
      "type": "remote",
      "url": "http://localhost:1153/mcp",
      "enabled": true,
      "oauth": false,
      "headers": {
        "directory": "broker"
      }
    },
    "groww": {
      "type": "remote",
      "url": "https://mcp.groww.in/mcp",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer "Groww Api Key"
    }
  }
}
